---
import SmoothScroll from '../components/SmoothScroll.astro';
import { getLocalizedPath as buildLocalizedPath, normalizeLang } from '../i18n/utils';
import { defaultLang, locales, type Lang } from '../i18n/ui';
import { ClientRouter } from 'astro:transitions';
import brandLogo from '../assets/200iq_logo.png';
import siteFavicon from '../assets/favicon.svg';
import fontStylesheetHref from '../styles/fonts.css?url';
import globalStylesheetHref from '../styles/global.css?url';
import homeCriticalCss from '../styles/critical-home.css?raw';
import interLatin400Woff2 from '@fontsource/inter/files/inter-latin-400-normal.woff2?url';
import interCyrillic400Woff2 from '@fontsource/inter/files/inter-cyrillic-400-normal.woff2?url';
import oswaldLatin700Woff2 from '@fontsource/oswald/files/oswald-latin-700-normal.woff2?url';
import oswaldCyrillic700Woff2 from '@fontsource/oswald/files/oswald-cyrillic-700-normal.woff2?url';
import spaceGroteskLatin600Woff2 from '@fontsource/space-grotesk/files/space-grotesk-latin-600-normal.woff2?url';
import spaceGroteskLatin700Woff2 from '@fontsource/space-grotesk/files/space-grotesk-latin-700-normal.woff2?url';

interface Props {
	lang: string;
	title: string;
	description: string;
}

const { lang, title, description } = Astro.props;
const activeLang = normalizeLang(lang);
const currentPath = Astro.url.pathname;
const currentSegments = currentPath.split('/').filter(Boolean);
const contentSegments = locales.includes(currentSegments[0] as Lang) ? currentSegments.slice(1) : currentSegments;
const isHomePage = contentSegments.length === 0;
const siteOrigin = (Astro.site?.toString() ?? Astro.url.origin).replace(/\/$/, '');
const canonicalUrl = new URL(currentPath, siteOrigin).toString();
const socialImagePath = typeof brandLogo === 'string' ? brandLogo : brandLogo.src;
const faviconHref = typeof siteFavicon === 'string' ? siteFavicon : siteFavicon.src;
const socialImageUrl = new URL(socialImagePath, siteOrigin).toString();
const structuredData = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'Organization',
			'@id': `${siteOrigin}/#organization`,
			name: '200IQ',
			url: siteOrigin,
			logo: {
				'@type': 'ImageObject',
				url: socialImageUrl,
			},
			email: 'oto@200iq.eu',
			telephone: '+37126678242',
			address: {
				'@type': 'PostalAddress',
				streetAddress: 'Gaileņu iela 22',
				addressLocality: 'Riga',
				postalCode: 'LV-1023',
				addressCountry: 'LV',
			},
		},
		{
			'@type': 'WebSite',
			'@id': `${siteOrigin}/#website`,
			url: siteOrigin,
			name: '200IQ',
			inLanguage: locales,
			publisher: {
				'@id': `${siteOrigin}/#organization`,
			},
		},
		{
			'@type': 'WebPage',
			'@id': `${canonicalUrl}#webpage`,
			url: canonicalUrl,
			name: title,
			description,
			inLanguage: activeLang,
			isPartOf: {
				'@id': `${siteOrigin}/#website`,
			},
			about: {
				'@id': `${siteOrigin}/#organization`,
			},
			primaryImageOfPage: {
				'@type': 'ImageObject',
				url: socialImageUrl,
			},
		},
	],
};
const ogLocaleMap: Record<Lang, string> = {
	en: 'en_US',
	lv: 'lv_LV',
	ru: 'ru_RU',
	et: 'et_EE',
};
const activeOgLocale = ogLocaleMap[activeLang];
const alternateOgLocales = locales.filter((locale) => locale !== activeLang).map((locale) => ogLocaleMap[locale]);
const isCyrillicLocale = activeLang === 'ru';
const interCriticalWoff2 = isCyrillicLocale ? interCyrillic400Woff2 : interLatin400Woff2;
const oswaldCriticalWoff2 = isCyrillicLocale ? oswaldCyrillic700Woff2 : oswaldLatin700Woff2;
const flagIconStylesheetHref = 'https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.3.2/css/flag-icons.min.css';
const nonHomeCriticalCss = `
	:root {
		color-scheme: only light;
		--container: 1120px;
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		min-height: 100%;
	}

	body {
		background: #120603;
		color: #f8ecdc;
		font-family: "Inter", system-ui, -apple-system, "Segoe UI", Roboto, Arial, sans-serif;
		line-height: 1.5;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	img,
	svg {
		display: block;
		max-width: 100%;
	}

	.container {
		width: min(var(--container), 92vw);
		margin-inline: auto;
	}
`;

const localizedContentPath = contentSegments.length > 0 ? `/${contentSegments.join('/')}` : '/';
const getLocalizedPath = (locale: Lang) => buildLocalizedPath(locale, localizedContentPath);
---

<!doctype html>
<html lang={activeLang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="color-scheme" content="light" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="200IQ" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={socialImageUrl} />
		<meta property="og:image:alt" content="200IQ logo" />
		<meta property="og:locale" content={activeOgLocale} />
			{
				alternateOgLocales.map((locale) => (
					<meta property="og:locale:alternate" content={locale} />
				))
			}
			<meta name="twitter:card" content="summary_large_image" />
			<meta name="twitter:title" content={title} />
			<meta name="twitter:description" content={description} />
			<meta name="twitter:image" content={socialImageUrl} />
			<meta name="twitter:image:alt" content="200IQ logo" />
			<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
			<link rel="icon" type="image/svg+xml" href={faviconHref} />
			{
				locales.map((locale) => (
					<link rel="alternate" hreflang={locale} href={`${siteOrigin}${getLocalizedPath(locale)}`} />
				))
			}
			<link rel="alternate" hreflang="x-default" href={`${siteOrigin}${getLocalizedPath(defaultLang)}`} />
			{
				isHomePage ? (
					<style is:inline set:html={homeCriticalCss}></style>
				) : (
					<style is:inline set:html={nonHomeCriticalCss}></style>
				)
			}
			<link
				rel="preload"
				as="style"
				href={flagIconStylesheetHref}
				onload="this.onload=null;this.rel='stylesheet'"
			/>
			<noscript><link rel="stylesheet" href={flagIconStylesheetHref} /></noscript>
			<link rel="preload" as="font" type="font/woff2" href={interCriticalWoff2} crossorigin />
			<link rel="preload" as="font" type="font/woff2" href={oswaldCriticalWoff2} crossorigin />
			<link rel="preload" as="font" type="font/woff2" href={spaceGroteskLatin600Woff2} crossorigin />
			<link rel="preload" as="font" type="font/woff2" href={spaceGroteskLatin700Woff2} crossorigin />
			<link rel="stylesheet" href={fontStylesheetHref} />
			{
				isHomePage ? (
					<>
						<link
							rel="preload"
							as="style"
							href={globalStylesheetHref}
							onload="this.onload=null;this.rel='stylesheet'"
						/>
						<noscript><link rel="stylesheet" href={globalStylesheetHref} /></noscript>
					</>
				) : (
					<link rel="stylesheet" href={globalStylesheetHref} />
				)
			}
			<title>{title}</title>
		<ClientRouter />
	</head>
		<body>
			<slot />
			<SmoothScroll />
		</body>
	</html>

<style is:global>
	/* Prevent Chromium-based auto darkening (Samsung Internet "Force Dark"). */
	:root {
		color-scheme: only light;
	}

	/* ── View Transition: Premium Crossfade ── */
	::view-transition-old(root) {
		animation: vt-fade-out 0.2s cubic-bezier(0.4, 0, 1, 1) forwards;
	}

	::view-transition-new(root) {
		animation: vt-fade-in 0.5s cubic-bezier(0, 0, 0.2, 1) forwards;
	}

	@keyframes vt-fade-out {
		from { opacity: 1; transform: scale(1); }
		to { opacity: 0; transform: scale(0.98); }
	}

	@keyframes vt-fade-in {
		from { opacity: 0; transform: translateY(20px) scale(1.01); }
		to { opacity: 1; transform: translateY(0) scale(1); }
	}
</style>
