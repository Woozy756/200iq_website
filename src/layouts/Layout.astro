---
import '../styles/global.css';
import { normalizeLang } from '../i18n/utils';

interface Props {
	lang: string;
	title: string;
	description: string;
}

const { lang, title, description } = Astro.props;
const activeLang = normalizeLang(lang);
---

<!doctype html>
<html lang={activeLang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="alternate" hreflang="en" href={`${Astro.url.origin}/en/`} />
		<link rel="alternate" hreflang="x-default" href={`${Astro.url.origin}/en/`} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@300;400;600;700&family=Space+Grotesk:wght@400;500;700&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
