---
import '../styles/global.css';
import SmoothScroll from '../components/SmoothScroll.astro';
import { normalizeLang } from '../i18n/utils';
import { defaultLang, locales, type Lang } from '../i18n/ui';
import { ClientRouter } from 'astro:transitions';

interface Props {
	lang: string;
	title: string;
	description: string;
}

const { lang, title, description } = Astro.props;
const activeLang = normalizeLang(lang);
const currentPath = Astro.url.pathname;
const siteOrigin = (Astro.site?.toString() ?? Astro.url.origin).replace(/\/$/, '');
const canonicalUrl = new URL(currentPath, siteOrigin).toString();
const socialImageUrl = new URL('/200iq_logo.png', siteOrigin).toString();
const structuredData = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'Organization',
			'@id': `${siteOrigin}/#organization`,
			name: '200IQ',
			url: siteOrigin,
			logo: {
				'@type': 'ImageObject',
				url: socialImageUrl,
			},
			email: 'oto@200iq.eu',
			telephone: '+37126678242',
			address: {
				'@type': 'PostalAddress',
				streetAddress: 'Gaileņu iela 22',
				addressLocality: 'Riga',
				postalCode: 'LV-1023',
				addressCountry: 'LV',
			},
		},
		{
			'@type': 'WebSite',
			'@id': `${siteOrigin}/#website`,
			url: siteOrigin,
			name: '200IQ',
			inLanguage: locales,
			publisher: {
				'@id': `${siteOrigin}/#organization`,
			},
		},
		{
			'@type': 'WebPage',
			'@id': `${canonicalUrl}#webpage`,
			url: canonicalUrl,
			name: title,
			description,
			inLanguage: activeLang,
			isPartOf: {
				'@id': `${siteOrigin}/#website`,
			},
			about: {
				'@id': `${siteOrigin}/#organization`,
			},
			primaryImageOfPage: {
				'@type': 'ImageObject',
				url: socialImageUrl,
			},
		},
	],
};
const ogLocaleMap: Record<Lang, string> = {
	en: 'en_US',
	lv: 'lv_LV',
	ru: 'ru_RU',
	et: 'et_EE',
};
const activeOgLocale = ogLocaleMap[activeLang];
const alternateOgLocales = locales.filter((locale) => locale !== activeLang).map((locale) => ogLocaleMap[locale]);

const getLocalizedPath = (locale: Lang) => {
	const segments = currentPath.split('/').filter(Boolean);
	const pathSegments = locales.includes(segments[0] as Lang) ? segments.slice(1) : segments;
	return pathSegments.length > 0 ? `/${locale}/${pathSegments.join('/')}` : `/${locale}/`;
};
---

<!doctype html>
<html lang={activeLang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="color-scheme" content="light" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="200IQ" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={socialImageUrl} />
		<meta property="og:image:alt" content="200IQ logo" />
		<meta property="og:locale" content={activeOgLocale} />
			{
				alternateOgLocales.map((locale) => (
					<meta property="og:locale:alternate" content={locale} />
				))
			}
			<meta name="twitter:card" content="summary_large_image" />
			<meta name="twitter:title" content={title} />
			<meta name="twitter:description" content={description} />
			<meta name="twitter:image" content={socialImageUrl} />
			<meta name="twitter:image:alt" content="200IQ logo" />
			<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
			<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
			{
				locales.map((locale) => (
					<link rel="alternate" hreflang={locale} href={`${siteOrigin}${getLocalizedPath(locale)}`} />
				))
			}
			<link rel="alternate" hreflang="x-default" href={`${siteOrigin}${getLocalizedPath(defaultLang)}`} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.3.2/css/flag-icons.min.css"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Oswald:wght@700&family=Space+Grotesk:wght@400;500;700&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
		<ClientRouter />
	</head>
	<body>
		<SmoothScroll />
		<slot />
	</body>
</html>

<style is:global>
	/* Prevent Chromium-based auto darkening (Samsung Internet "Force Dark"). */
	:root {
		color-scheme: only light;
	}

	/* ── View Transition: Premium Crossfade ── */
	::view-transition-old(root) {
		animation: vt-fade-out 0.2s cubic-bezier(0.4, 0, 1, 1) forwards;
	}

	::view-transition-new(root) {
		animation: vt-fade-in 0.5s cubic-bezier(0, 0, 0.2, 1) forwards;
	}

	@keyframes vt-fade-out {
		from { opacity: 1; transform: scale(1); }
		to { opacity: 0; transform: scale(0.98); }
	}

	@keyframes vt-fade-in {
		from { opacity: 0; transform: translateY(20px) scale(1.01); }
		to { opacity: 1; transform: translateY(0) scale(1); }
	}
</style>
