---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.jsx';
import NavMenuIsland from '../../islands/NavMenuIsland.jsx';
import FooterSection from '../../components/FooterSection.astro';
import { localeEndonyms } from '../../i18n/ui';
import { getDictionary, normalizeLang, useTranslations } from '../../i18n/utils';

const lang = normalizeLang('et');
const t = useTranslations(lang);
const dictionary = getDictionary(lang);

const navLinks = [
	{ label: t('navigation.links.process'), href: '/et/', targetId: 'process' },
	{ label: t('navigation.links.tech'), href: '/et/', targetId: 'tech' },
	{ label: t('navigation.links.network'), href: '/et/', targetId: 'network' },
];

const localeLinks = [
	{ code: 'lv', label: localeEndonyms.lv, flagCode: 'lv', href: '/lv/contact' },
	{ code: 'en', label: localeEndonyms.en, flagCode: 'gb', href: '/en/contact' },
	{ code: 'ru', label: localeEndonyms.ru, flagCode: 'ru', href: '/ru/contact' },
	{ code: 'et', label: localeEndonyms.et, flagCode: 'ee', href: '/et/contact' },
];
---

<Layout
	lang={lang}
	title={dictionary.metadata.contactTitle}
	description={dictionary.metadata.contactDescription}
>
	<NavMenuIsland
		client:load
		brand={t('navigation.brand')}
		links={navLinks}
		localeLinks={localeLinks}
		currentLocale={lang}
		ctaLabel={t('navigation.cta')}
		openMenuLabel={t('navigation.openMenu')}
		closeMenuLabel={t('navigation.closeMenu')}
		languageLabel={t('navigation.languageLabel')}
	/>

	<main class="contact-main">
		<section class="hero section contact-hero">
			<div class="container hero-content">
				<div class="hero-grid contact-grid">
					<div class="hero-main">
						<p class="eyebrow">{t('contact.eyebrow')}</p>
						<h1 class="hero-title">
							{t('contact.titleStart')} <span class="accent">{t('contact.titleHighlight')}</span>
						</h1>
						<p class="hero-lead mt-6">
							{t('contact.lead')}
						</p>
					</div>
					<div class="contact-form-wrapper panel">
						<ContactForm client:visible t={dictionary.contact.form} />
					</div>
				</div>
			</div>
		</section>
	</main>

	<FooterSection lang={lang} />
</Layout>

<style>
	.contact-main {
		padding-top: 0;
	}
	
	.contact-hero {
		min-height: 100vh;
		display: flex;
		align-items: center;
		position: relative;
		background:
			radial-gradient(115% 72% at 50% 10%, rgba(225, 161, 64, 0.08), transparent 58%),
			linear-gradient(180deg, rgba(8, 3, 1, 0.34) 0%, rgba(27, 11, 4, 0.97) 100%);
	}

	.contact-hero::before {
		content: '';
		position: absolute;
		inset: 0;
		background:
			linear-gradient(to right, rgba(225, 161, 64, 0.04) 1px, transparent 1px),
			linear-gradient(to bottom, rgba(225, 161, 64, 0.04) 1px, transparent 1px);
		background-size: 44px 44px;
		opacity: 0.8;
		z-index: 1;
		pointer-events: none;
	}

	.contact-grid {
		grid-template-columns: 1fr 1.15fr;
		gap: clamp(2rem, 5vw, 4rem);
		align-items: center;
	}

	@media (max-width: 900px) {
		.contact-grid {
			grid-template-columns: 1fr;
			gap: 3.5rem;
		}

		.contact-form-wrapper {
			padding-inline: 0;
			width: 100%;
		}
	}

	.mt-6 {
		margin-top: 1.5rem;
	}

	.contact-form-wrapper {
		padding: clamp(1.5rem, 4vw, 3rem);
		z-index: 2;
	}
</style>
