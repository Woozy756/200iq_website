---
import RobotHeadIsland from '../islands/RobotHeadIsland.jsx';
import { getDictionary, normalizeLang, useTranslations } from '../i18n/utils';

interface Props {
	lang: string;
}

const lang = normalizeLang(Astro.props.lang);
const t = useTranslations(lang);
const dictionary = getDictionary(lang);
---

<section id="vision" class="section">
	<div class="container split-grid">
		<div class="copy-block">
			<span class="eyebrow">{t('vision.eyebrow')}</span>
			<h2 class="section-title">{t('vision.title')}</h2>
			<p class="muted">{t('vision.body1')}</p>
			<p class="muted">{t('vision.body2')}</p>
			<ul class="bullet-list">
				{
					dictionary.vision.bullets.map((bullet) => (
						<li>{bullet}</li>
					))
				}
			</ul>
		</div>
		<div class="panel">
			<RobotHeadIsland client:visible />
		</div>
	</div>
</section>
