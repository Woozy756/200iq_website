---
import MountainProcessIsland from '../islands/MountainProcessIsland.jsx';
import { getDictionary, normalizeLang, useTranslations } from '../i18n/utils';

interface Props {
	lang: string;
}

const lang = normalizeLang(Astro.props.lang);
const t = useTranslations(lang);
const dictionary = getDictionary(lang);
---

<section id="process" class="process-shell">
	<div class="container process-header-wrap">
		<div class="process-header">
			<span class="eyebrow">{t('process.eyebrow')}</span>
			<h2 class="section-title">{t('process.title')}</h2>
			<p class="muted">{t('process.description')}</p>
		</div>
	</div>
	<MountainProcessIsland client:visible steps={dictionary.process.steps} />
</section>
