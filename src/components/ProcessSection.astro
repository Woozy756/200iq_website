---
import MountainProcessIsland from '../islands/MountainProcessIsland.jsx';
import { getDictionary, normalizeLang, useTranslations } from '../i18n/utils';

interface Props {
	lang: string;
}

const lang = normalizeLang(Astro.props.lang);
const t = useTranslations(lang);
const dictionary = getDictionary(lang);
---

<section id="process" class="process-shell">
	<div class="process-upper">
		<span class="process-badge">
			<i class="process-badge-dot" aria-hidden="true"></i>
			{t('process.eyebrow')}
		</span>
		<h2 class="process-hero-title">{dictionary.process.titleStart} <span class="process-title-highlight">{dictionary.process.titleHighlight}</span></h2>
		<p class="process-hero-desc">{t('process.description')}</p>
	</div>
	<MountainProcessIsland client:visible steps={dictionary.process.steps} />
	<div class="section-divider is-bottom" aria-hidden="true"></div>
</section>
