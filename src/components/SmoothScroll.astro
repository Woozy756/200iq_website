<script>
	import Lenis from 'lenis';

	let lenis;
	let rafId = 0;

	function destroyLenis() {
		if (rafId) {
			cancelAnimationFrame(rafId);
			rafId = 0;
		}

		if (lenis) {
			lenis.destroy();
			lenis = undefined;
		}
	}

	function setupLenis() {
		destroyLenis();

		lenis = new Lenis({
			smoothWheel: true,
		});

		const raf = (time) => {
			if (lenis) {
				lenis.raf(time);
				rafId = requestAnimationFrame(raf);
			}
		};

		rafId = requestAnimationFrame(raf);
	}

	document.addEventListener('astro:before-swap', destroyLenis);
	document.addEventListener('astro:page-load', setupLenis);

	setupLenis();
</script>

<style is:global>
	html.lenis {
		scroll-behavior: auto !important;
	}

	html.lenis,
	html.lenis body {
		height: auto;
	}
</style>
