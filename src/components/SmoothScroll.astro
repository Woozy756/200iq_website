<script>
	import Lenis from 'lenis';

	let lenis;
	let rafId = 0;
	let mediaQuery;
	const pendingNavTargetKey = '__pendingNavTarget';
	const pendingNavTransitionKey = '__pendingNavTransition';
	const processSnapKey = '__forceProcessSnap';

	function stopRaf() {
		if (rafId) {
			cancelAnimationFrame(rafId);
			rafId = 0;
		}
	}

	function stopLenisMotion() {
		stopRaf();
		if (lenis && typeof lenis.stop === 'function') {
			lenis.stop();
		}
	}

	function startLenisMotion() {
		if (lenis && typeof lenis.start === 'function') {
			lenis.start();
		}
		if (lenis && !rafId) {
			startRaf();
		}
	}

	function jumpToTarget(target) {
		if (!target) return;
		if (target.id === 'process') {
			window[processSnapKey] = true;
		}
		if (lenis) {
			lenis.scrollTo(target, { immediate: true, force: true });
			return;
		}

		const targetY = target.getBoundingClientRect().top + (window.scrollY || window.pageYOffset || 0);
		window.scrollTo(0, targetY);
	}

	function runSectionTransition(work) {
		stopLenisMotion();

		if (typeof document.startViewTransition === 'function') {
			const transition = document.startViewTransition(() => {
				work();
			});

			transition.finished.finally(() => {
				startLenisMotion();
			});
			return;
		}

		work();
		startLenisMotion();
	}

	function destroyLenis() {
		stopRaf();
		if (lenis) {
			lenis.destroy();
			lenis = undefined;
		}
		delete window.__lenis;
		delete window.__jumpToTargetWithTransition;
	}

	function startRaf() {
		const raf = (time) => {
			if (!lenis) return;
			lenis.raf(time);
			rafId = requestAnimationFrame(raf);
		};

		rafId = requestAnimationFrame(raf);
	}

	function jumpToTargetWithTransition(target) {
		if (!target) return;

		runSectionTransition(() => {
			jumpToTarget(target);
		});
	}

	function consumePendingTarget() {
		const targetId = window.sessionStorage.getItem(pendingNavTargetKey);
		window.sessionStorage.removeItem(pendingNavTargetKey);
		const shouldTransition = window.sessionStorage.getItem(pendingNavTransitionKey) === '1';
		window.sessionStorage.removeItem(pendingNavTransitionKey);
		if (!targetId) {
			return;
		}

		const target = document.getElementById(targetId);
		if (!target) {
			return;
		}

		requestAnimationFrame(() => {
			requestAnimationFrame(() => {
				if (shouldTransition) {
					runSectionTransition(() => {
						jumpToTarget(target);
					});
					return;
				}

				jumpToTarget(target);
			});
		});
	}

	function setupLenis() {
		destroyLenis();
		window.__jumpToTargetWithTransition = jumpToTargetWithTransition;

		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
			consumePendingTarget();
			return;
		}

		lenis = new Lenis({
			duration: 1.05,
			easing: (t) => (t === 1 ? 1 : 1 - 2 ** (-10 * t)),
			smoothWheel: true,
			syncTouch: true,
			gestureOrientation: 'vertical',
			anchors: true,
		});

		window.__lenis = lenis;
		startRaf();
		consumePendingTarget();
	}

	function setupReducedMotionListener() {
		mediaQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
		const handleChange = () => setupLenis();

		if (typeof mediaQuery.addEventListener === 'function') {
			mediaQuery.addEventListener('change', handleChange);
			return;
		}

		if (typeof mediaQuery.addListener === 'function') {
			mediaQuery.addListener(handleChange);
		}
	}

	document.addEventListener('astro:before-swap', destroyLenis);
	document.addEventListener('astro:page-load', setupLenis);
	window.addEventListener('pageshow', setupLenis);
	window.addEventListener('beforeunload', destroyLenis);

	setupReducedMotionListener();
	setupLenis();
</script>

<style is:global>
	html.lenis,
	html.lenis body {
		height: auto;
	}

	html.lenis.lenis-smooth {
		scroll-behavior: auto !important;
	}

	html.lenis.lenis-stopped {
		overflow: hidden;
	}

	html.lenis.lenis-smooth [data-lenis-prevent] {
		overscroll-behavior: contain;
	}

	body::before {
		content: none;
	}
</style>
