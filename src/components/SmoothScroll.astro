<script>
	const CONTROLLER_KEY = '__smoothScrollController';
	const LENIS_CONSTRUCTOR_KEY = '__lenisConstructor';
	const LENIS_LOADER_KEY = '__lenisLoaderPromise';
	const pendingNavTargetKey = '__pendingNavTarget';
	const pendingNavTransitionKey = '__pendingNavTransition';
	const processSnapKey = '__forceProcessSnap';
	const LENIS_DESKTOP_MIN_WIDTH = 981;
	const INTERACTION_EVENTS = ['wheel', 'touchstart', 'keydown', 'mousedown'];

	const loadLenisConstructor = () => {
		if (window[LENIS_CONSTRUCTOR_KEY]) {
			return Promise.resolve(window[LENIS_CONSTRUCTOR_KEY]);
		}

		if (!window[LENIS_LOADER_KEY]) {
			window[LENIS_LOADER_KEY] = import('lenis')
				.then((module) => {
					const LenisCtor = module?.default || module?.Lenis || module;
					window[LENIS_CONSTRUCTOR_KEY] = LenisCtor;
					return LenisCtor;
				})
				.catch(() => null)
				.finally(() => {
					delete window[LENIS_LOADER_KEY];
				});
		}

		return window[LENIS_LOADER_KEY];
	};

	function createController() {
		let lenis = null;
		let afterSwapFrame = 0;
		let pageLoadFrame = 0;
		let viewportMode = null;
		let loadingLenis = false;
		let destroyed = false;
		let hasUserInteraction = false;

		const cancelFrame = (frameId) => {
			if (frameId) {
				cancelAnimationFrame(frameId);
			}
			return 0;
		};

		const clearFrames = () => {
			afterSwapFrame = cancelFrame(afterSwapFrame);
			pageLoadFrame = cancelFrame(pageLoadFrame);
		};

		const isDesktopViewport = () => (window.innerWidth || 0) >= LENIS_DESKTOP_MIN_WIDTH;

		const clearLenisClasses = () => {
			document.documentElement.classList.remove('lenis', 'lenis-smooth', 'lenis-stopped');
			document.body.classList.remove('lenis', 'lenis-smooth', 'lenis-stopped');
		};

		const destroyLenis = () => {
			if (!lenis) return;
			lenis.destroy();
			lenis = null;
			delete window.__lenis;
			clearLenisClasses();
		};

		const ensureLenis = () => {
			if (destroyed || loadingLenis || lenis || !isDesktopViewport()) {
				return;
			}

			loadingLenis = true;
			loadLenisConstructor()
				.then((LenisCtor) => {
					if (!LenisCtor || destroyed || lenis || !isDesktopViewport()) {
						return;
					}

					lenis = new LenisCtor({
						autoRaf: true,
						smoothWheel: true,
						syncTouch: true,
						gestureOrientation: 'vertical',
						anchors: false,
						overscroll: true,
						lerp: 0.085,
						wheelMultiplier: 0.95,
					});

					window.__lenis = lenis;
					syncLenis();
				})
				.finally(() => {
					loadingLenis = false;
				});
		};

		const getLenis = () => {
			if (!isDesktopViewport()) {
				return null;
			}

			ensureLenis();
			return lenis;
		};

		const syncLenis = () => {
			const instance = getLenis();
			if (!instance) return;
			instance.resize();
			instance.scrollTo(window.scrollY || window.pageYOffset || 0, {
				immediate: true,
				force: true,
			});
		};

		const jumpToTarget = (target) => {
			if (!target) return;

			if (target.id === 'process') {
				window[processSnapKey] = true;
			}

			const instance = getLenis();
			if (instance) {
				instance.scrollTo(target, {
					immediate: true,
					force: true,
				});
				return;
			}

			target.scrollIntoView({
				behavior: 'auto',
				block: 'start',
			});
		};

		const withViewTransition = (work) => {
			const instance = getLenis();
			if (!instance) {
				if (typeof document.startViewTransition === 'function') {
					document.startViewTransition(work);
					return;
				}
				work();
				return;
			}

			instance.stop();

			if (typeof document.startViewTransition === 'function') {
				const transition = document.startViewTransition(work);
				transition.finished.finally(() => {
					syncLenis();
					instance.start();
				});
				return;
			}

			work();
			syncLenis();
			instance.start();
		};

		const consumePendingTarget = () => {
			const targetId = window.sessionStorage.getItem(pendingNavTargetKey);
			window.sessionStorage.removeItem(pendingNavTargetKey);
			const shouldTransition = window.sessionStorage.getItem(pendingNavTransitionKey) === '1';
			window.sessionStorage.removeItem(pendingNavTransitionKey);

			if (!targetId) return;

			const target = document.getElementById(targetId);
			if (!target) return;

			requestAnimationFrame(() => {
				requestAnimationFrame(() => {
					if (shouldTransition) {
						withViewTransition(() => {
							jumpToTarget(target);
						});
						return;
					}

					jumpToTarget(target);
				});
			});
		};

		const refreshLenisMode = () => {
			const isDesktop = isDesktopViewport();
			if (viewportMode === isDesktop) return;
			viewportMode = isDesktop;

			if (isDesktop) {
				if (hasUserInteraction) {
					ensureLenis();
					syncLenis();
				}
				return;
			}

			destroyLenis();
		};

		const onFirstInteraction = () => {
			if (destroyed || hasUserInteraction) return;
			hasUserInteraction = true;
			if (isDesktopViewport()) {
				ensureLenis();
				syncLenis();
			}
		};

		const handleBeforeSwap = () => {
			clearFrames();
			if (!lenis) return;
			lenis.stop();
		};

		const handleAfterSwap = () => {
			clearFrames();
			if (!lenis) return;

			afterSwapFrame = requestAnimationFrame(() => {
				if (!lenis) return;
				syncLenis();
				lenis.start();
			});
		};

		const handlePageLoad = () => {
			pageLoadFrame = cancelFrame(pageLoadFrame);
			pageLoadFrame = requestAnimationFrame(() => {
				refreshLenisMode();
				syncLenis();
				consumePendingTarget();
			});
		};

		const mount = () => {
			window.__jumpToTargetWithTransition = (target) => {
				if (!target) return;
				withViewTransition(() => {
					jumpToTarget(target);
				});
			};

			INTERACTION_EVENTS.forEach((eventName) => {
				window.addEventListener(eventName, onFirstInteraction, { passive: true, once: true });
			});

			refreshLenisMode();
			handlePageLoad();
		};

		const destroy = () => {
			destroyed = true;
			clearFrames();
			document.removeEventListener('astro:before-swap', handleBeforeSwap);
			document.removeEventListener('astro:after-swap', handleAfterSwap);
			document.removeEventListener('astro:page-load', handlePageLoad);
			window.removeEventListener('pageshow', handlePageLoad);
			window.removeEventListener('resize', refreshLenisMode);
			window.removeEventListener('beforeunload', destroy);
			INTERACTION_EVENTS.forEach((eventName) => {
				window.removeEventListener(eventName, onFirstInteraction);
			});

			destroyLenis();

			delete window.__jumpToTargetWithTransition;
			delete window[CONTROLLER_KEY];
		};

		document.addEventListener('astro:before-swap', handleBeforeSwap);
		document.addEventListener('astro:after-swap', handleAfterSwap);
		document.addEventListener('astro:page-load', handlePageLoad);
		window.addEventListener('pageshow', handlePageLoad);
		window.addEventListener('resize', refreshLenisMode);
		window.addEventListener('beforeunload', destroy);

		return {
			mount,
			destroy,
		};
	}

	const mountController = () => {
		const existingController = window[CONTROLLER_KEY];
		if (existingController && typeof existingController.mount === 'function') {
			existingController.mount();
			return;
		}

		const controller = createController();
		window[CONTROLLER_KEY] = controller;
		controller.mount();
	};

	const scheduleControllerMount = () => {
		const runMount = () => {
			if ('requestIdleCallback' in window) {
				window.requestIdleCallback(() => {
					mountController();
				}, { timeout: 1200 });
				return;
			}

			window.setTimeout(mountController, 120);
		};

		if (document.readyState === 'complete') {
			runMount();
			return;
		}

		window.addEventListener('load', runMount, { once: true });
	};

	scheduleControllerMount();
</script>

<style is:global>
	html.lenis,
	html.lenis body {
		height: auto;
	}

	html.lenis.lenis-smooth {
		scroll-behavior: auto !important;
	}

	.lenis:not(.lenis-autoToggle).lenis-stopped {
		overflow: clip;
	}

	.lenis [data-lenis-prevent],
	.lenis [data-lenis-prevent-wheel],
	.lenis [data-lenis-prevent-touch],
	.lenis [data-lenis-prevent-vertical],
	.lenis [data-lenis-prevent-horizontal] {
		overscroll-behavior: contain;
	}

	.lenis.lenis-smooth iframe {
		pointer-events: none;
	}
</style>
