---
import { normalizeLang, useTranslations } from '../i18n/utils';

interface Props {
	lang: string;
}

const lang = normalizeLang(Astro.props.lang);
const t = useTranslations(lang);
---

<section id="network" class="section network-band">
	<div class="container">
		<h2 class="section-title">{t('network.titleStart')} <br /> {t('network.titleEnd')}</h2>
		<p class="muted">{t('network.body')}</p>
		<div style="margin-top: 1.8rem;">
			<a href={`/${lang}/contact`} class="btn btn-dark">{t('network.cta')}</a>
		</div>
	</div>
</section>
