---
import ServicesHorizontalIsland from '../islands/ServicesHorizontalIsland.jsx';
import { getDictionary, normalizeLang } from '../i18n/utils';

interface Props {
	lang: string;
}

const lang = normalizeLang(Astro.props.lang);
const dictionary = getDictionary(lang);
---

<div class="svcx-shell">
	<ServicesHorizontalIsland client:load cards={dictionary.services.cards} />
	<div class="section-divider is-bottom" aria-hidden="true"></div>
</div>
