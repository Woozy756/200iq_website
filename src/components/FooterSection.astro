---
import { getLocalizedPath, normalizeLang, useTranslations } from '../i18n/utils';

interface Props {
	lang: string;
}

const lang = normalizeLang(Astro.props.lang);
const t = useTranslations(lang);
const facebookHref = t('footer.facebookHref');
---

<footer id="join" class="site-footer">
	<div class="container">
		<div class="footer-grid">
			<div>
				<h2 class="footer-title">
					{t('footer.titleStart')} <br /> <span class="accent">{t('footer.titleHighlight')}</span>
				</h2>
				<a class="btn btn-primary" href={getLocalizedPath(lang, '/contact')}>{t('footer.cta')}</a>
			</div>
			<div class="footer-columns">
				<div class="footer-social-column">
					<span class="footer-column-title">{t('footer.socialTitle')}</span>
					<a class="footer-facebook-btn" href={facebookHref} aria-label={t('footer.facebookAriaLabel')}>
						<span class="footer-facebook-icon" aria-hidden="true">
							<svg viewBox="0 0 24 24" focusable="false">
								<path
									fill="currentColor"
									d="M13.66 21v-8.04h2.7l.4-3.13h-3.1V7.84c0-.91.25-1.53 1.56-1.53h1.67V3.5c-.29-.04-1.28-.12-2.43-.12-2.4 0-4.05 1.46-4.05 4.16v2.29H7.69v3.13h2.72V21h3.25Z"
								/>
							</svg>
						</span>
						<span>{t('footer.facebookLabel')}</span>
					</a>
				</div>
				<div class="footer-contact-column">
					<span class="footer-column-title">{t('footer.contactTitle')}</span>
					<div class="footer-contact-links">
						<a class="footer-contact-link" href={`mailto:${t('footer.email')}`} aria-label={t('footer.emailAriaLabel')}>
							<svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
								<path
									fill="currentColor"
									d="M4 6h16a2 2 0 0 1 2 2v.24l-10 6.25-10-6.25V8a2 2 0 0 1 2-2Zm18 4.56V16a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-5.44l9.47 5.92a1 1 0 0 0 1.06 0L22 10.56Z"
								/>
							</svg>
							<span>{t('footer.email')}</span>
						</a>
						<a class="footer-contact-link" href={t('footer.phoneHref')} aria-label={t('footer.phoneAriaLabel')}>
							<svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
								<path
									fill="currentColor"
									d="M6.6 2h3.12a1 1 0 0 1 .98.8l.56 3.07a1 1 0 0 1-.29.91L8.86 8.9a15.08 15.08 0 0 0 6.24 6.24l2.12-2.11a1 1 0 0 1 .91-.29l3.07.56a1 1 0 0 1 .8.98v3.12a1 1 0 0 1-.9 1A17.6 17.6 0 0 1 4.5 3.9a1 1 0 0 1 1-.9Z"
								/>
							</svg>
							<span>{t('footer.phone')}</span>
						</a>
					</div>
				</div>
				<div class="footer-company-column">
					<span class="footer-column-title">{t('footer.companyTitle')}</span>
					<div class="footer-company-details" aria-label={t('footer.companyAriaLabel')}>
						<p class="footer-company-line footer-company-name">{t('footer.companyName')}</p>
						<p class="footer-company-line footer-company-meta">{t('footer.registrationNo')}</p>
						<p class="footer-company-line footer-company-address">{t('footer.companyAddress')}</p>
					</div>
				</div>
			</div>
		</div>
		<div class="footer-bottom">
			<p class="footer-small">{t('footer.copyright')}</p>
			<div class="footer-inline">
				<p class="footer-small">{t('footer.builtFor')}</p>
			</div>
		</div>
	</div>
</footer>
