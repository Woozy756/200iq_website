---
import FooterSection from './FooterSection.astro';
import IntroSection from './IntroSection.astro';
import NavMenu from './NavMenu.astro';
import NetworkSection from './NetworkSection.astro';
import ProcessSection from './ProcessSection.astro';
import ScrollProgress from './ScrollProgress.astro';
import ServicesSection from './ServicesSection.astro';
import StatsSection from './StatsSection.astro';
import TechSection from './TechSection.astro';
import { localeEndonyms } from '../i18n/ui';
import { getLocalizedPath, normalizeLang, useTranslations } from '../i18n/utils';
import { getImage } from 'astro:assets';
import brandLogo from '../assets/200iq_logo.png';

interface Props {
	lang: string;
}

const lang = normalizeLang(Astro.props.lang);
const t = useTranslations(lang);
const [navLogoSm, navLogoMd, navLogoLg] = await Promise.all([
	getImage({ src: brandLogo, width: 160, format: 'png' }),
	getImage({ src: brandLogo, width: 260, format: 'png' }),
	getImage({ src: brandLogo, width: 420, format: 'png' }),
]);
const navLogoSrcSet = `${navLogoSm.src} 160w, ${navLogoMd.src} 260w, ${navLogoLg.src} 420w`;
const navLogoSizes = '(max-width: 720px) 124px, 208px';

const navLinks = [
	{ label: t('navigation.links.process'), href: getLocalizedPath(lang), targetId: 'process' },
	{ label: t('navigation.links.tech'), href: getLocalizedPath(lang), targetId: 'tech' },
	{ label: t('navigation.links.network'), href: getLocalizedPath(lang), targetId: 'network' },
];

const localeLinks = [
	{ code: 'lv', label: localeEndonyms.lv, flagCode: 'lv', href: getLocalizedPath('lv') },
	{ code: 'en', label: localeEndonyms.en, flagCode: 'gb', href: getLocalizedPath('en') },
	{ code: 'ru', label: localeEndonyms.ru, flagCode: 'ru', href: getLocalizedPath('ru') },
	{ code: 'et', label: localeEndonyms.et, flagCode: 'ee', href: getLocalizedPath('et') },
];
---

<ScrollProgress />
<NavMenu
	brand={t('navigation.brand')}
	links={navLinks}
	localeLinks={localeLinks}
	currentLocale={lang}
	logoSrc={navLogoMd.src}
	logoSrcSet={navLogoSrcSet}
	logoSizes={navLogoSizes}
	logoWidth={260}
	logoHeight={77}
	ctaLabel={t('navigation.cta')}
	openMenuLabel={t('navigation.openMenu')}
	closeMenuLabel={t('navigation.closeMenu')}
	languageLabel={t('navigation.languageLabel')}
/>

<main>
	<IntroSection lang={lang} />
	<ProcessSection lang={lang} />
	<ServicesSection lang={lang} />
	<TechSection lang={lang} />
	<StatsSection lang={lang} />
	<NetworkSection lang={lang} />
</main>

<FooterSection lang={lang} />
