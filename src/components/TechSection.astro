---
import { getDictionary, normalizeLang, useTranslations } from '../i18n/utils';

interface Props {
	lang: string;
}

const lang = normalizeLang(Astro.props.lang);
const t = useTranslations(lang);
const dictionary = getDictionary(lang);
---

<section id="tech" class="section tech-shell">
	<div class="container split-grid">
		<div class="copy-block">
			<span class="eyebrow">{t('tech.eyebrow')}</span>
			<h2 class="section-title">{t('tech.title')}</h2>
			<p class="muted">{t('tech.body')}</p>
		</div>
		<div class="panel" style="padding: 1.2rem;">
			<div class="metric-grid">
				{
					dictionary.tech.metrics.map((metric) => (
						<div class="metric">
							<p class="metric-value">{metric.value}</p>
							<p class="metric-label">{metric.label}</p>
						</div>
					))
				}
			</div>
		</div>
	</div>
</section>
