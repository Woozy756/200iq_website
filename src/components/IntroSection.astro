---
import { normalizeLang, useTranslations } from '../i18n/utils';

interface Props {
	lang: string;
}

const lang = normalizeLang(Astro.props.lang);
const t = useTranslations(lang);
---

<section class="hero section">
	<!-- Floating sparkle particles -->
	<div class="sparkles-layer" aria-hidden="true">
		<span class="spark" style="--x:12%;--y:18%;--s:7px;--dur:2.8s;--delay:0s"></span>
		<span class="spark" style="--x:28%;--y:72%;--s:5px;--dur:3.4s;--delay:0.6s"></span>
		<span class="spark" style="--x:44%;--y:35%;--s:9px;--dur:2.2s;--delay:1.1s"></span>
		<span class="spark" style="--x:60%;--y:58%;--s:6px;--dur:3.8s;--delay:0.3s"></span>
		<span class="spark" style="--x:75%;--y:22%;--s:8px;--dur:2.6s;--delay:1.5s"></span>
		<span class="spark" style="--x:88%;--y:80%;--s:5px;--dur:3.1s;--delay:0.9s"></span>
		<span class="spark" style="--x:20%;--y:88%;--s:6px;--dur:2.4s;--delay:2.0s"></span>
		<span class="spark" style="--x:52%;--y:10%;--s:10px;--dur:3.6s;--delay:0.4s"></span>
		<span class="spark" style="--x:36%;--y:92%;--s:5px;--dur:2.9s;--delay:1.7s"></span>
		<span class="spark" style="--x:82%;--y:44%;--s:7px;--dur:3.3s;--delay:0.2s"></span>
		<span class="spark" style="--x:68%;--y:68%;--s:6px;--dur:2.1s;--delay:2.2s"></span>
		<span class="spark" style="--x:92%;--y:15%;--s:8px;--dur:3.7s;--delay:1.3s"></span>
	</div>

	<div class="container hero-content">
		<h1 class="hero-title">
			{t('intro.titleStart')} <span class="accent">{t('intro.titleHighlight')}</span><br />{t(
				'intro.titleEnd',
			)}
		</h1>
		<p class="hero-kicker">{t('intro.kicker')}</p>
		<p class="hero-lead">{t('intro.lead')}</p>
		<div class="hero-actions">
			<a href="#process" class="btn btn-primary">{t('navigation.cta')}</a>
			<a href="#tech" class="btn btn-dark">{t('navigation.links.tech')}</a>
		</div>
	</div>
</section>

<style>
.sparkles-layer {
	position: absolute;
	inset: 0;
	pointer-events: none;
	z-index: 0;
}

.spark {
	position: absolute;
	left: var(--x);
	top: var(--y);
	width: var(--s);
	height: var(--s);
	opacity: 0;
	animation: spark-pop var(--dur) ease-in-out var(--delay) infinite;
}

.spark::before,
.spark::after {
	content: '';
	position: absolute;
	inset: 0;
	background: #F5D576;
	box-shadow: 0 0 8px 2px rgba(245, 213, 118, 0.9), 0 0 20px 4px rgba(201, 168, 76, 0.4);
	clip-path: polygon(50% 0%, 58% 38%, 100% 50%, 58% 62%, 50% 100%, 42% 62%, 0% 50%, 42% 38%);
}

.spark::after {
	transform: rotate(45deg);
	opacity: 0.5;
	background: #fff;
	box-shadow: 0 0 6px 1px rgba(255, 255, 255, 0.8);
}

@keyframes spark-pop {
	0%   { transform: scale(0) rotate(0deg);    opacity: 0; }
	35%  { transform: scale(1.3) rotate(60deg); opacity: 1; }
	65%  { transform: scale(0.9) rotate(130deg); opacity: 0.7; }
	100% { transform: scale(0) rotate(200deg);  opacity: 0; }
}
</style>
