---
import HeroFluidBackgroundIsland from '/src/islands/HeroFluidBackgroundIsland.jsx';
import { getLocalizedPath, normalizeLang, useTranslations } from '../i18n/utils';

interface Props {
	lang: string;
}

const lang = normalizeLang(Astro.props.lang);
const t = useTranslations(lang);
---

	<section class="hero section">
		<div class="hero-stage">
			<HeroFluidBackgroundIsland client:idle />

		<div class="container hero-content">
			<div class="hero-grid">
				<div class="hero-main">
					<p class="hero-kicker">{t('intro.kicker')}</p>
					<h1 class="hero-title">
						{t('intro.titleStart')} <span class="accent">{t('intro.titleHighlight')}</span><br />{t(
							'intro.titleEnd',
						)}
					</h1>
					<p class="hero-prompt">{t('intro.readyPrompt')}</p>
					<div class="hero-actions">
						<a href={getLocalizedPath(lang, '/contact')} class="btn btn-primary">{t('intro.primaryCta')}</a>
						<a href="#tech" class="btn btn-dark hero-secondary-btn">{t('intro.secondaryCta')}</a>
					</div>
				</div>
				<div class="hero-side">
					<div class="hero-side-viewport">
						<p class="hero-lead cool-split">{t('intro.lead')}</p>
					</div>
				</div>
			</div>
		</div>
	</div>
	<div class="section-divider is-bottom" aria-hidden="true"></div>
</section>

	<script is:inline type="module">
		function initCoolSplit() {
			if (window.__coolSplitCleanup) {
				window.__coolSplitCleanup();
				window.__coolSplitCleanup = null;
			}

			const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

		const splitParagraph = (element) => {
			const existingOriginalText = element.dataset.splitOriginalText;
			const text = typeof existingOriginalText === 'string' ? existingOriginalText : (element.textContent || '');
			if (!text.trim()) return null;
			if (element.dataset.splitDone === 'true') {
				element.textContent = text;
				element.style.transform = '';
			}
			element.dataset.splitOriginalText = text;
			element.textContent = '';

			const srText = document.createElement('span');
			srText.textContent = text;
			srText.style.cssText =
				'position:absolute;width:1px;height:1px;margin:-1px;padding:0;border:0;overflow:hidden;clip:rect(0 0 0 0);clip-path:inset(50%);white-space:nowrap;';

			const visualLayer = document.createElement('span');
			visualLayer.setAttribute('aria-hidden', 'true');

			const chars = [];

			Array.from(text).forEach((character) => {
				if (character === ' ') {
					visualLayer.appendChild(document.createTextNode(' '));
					return;
				}

				const span = document.createElement('span');
				span.className = 'char';
				span.textContent = character;
				span.style.setProperty('--reveal', '0');
				span.setAttribute('aria-hidden', 'true');
				visualLayer.appendChild(span);
				chars.push(span);
			});

			element.append(srText, visualLayer);
			element.dataset.splitDone = 'true';
			const viewport = element.parentElement;
			if (!(viewport instanceof HTMLElement)) {
				return null;
			}
			const hero = element.closest('.hero');
			const charPositions = new Float32Array(chars.length);
			const metrics = {
				heroStart: 0,
				heroTravel: 1,
				paragraphHeight: 1,
				viewportHeight: 1,
				maxTranslate: 0,
				fadeZone: 1,
				middleOffset: 1,
				scrollDenominator: 1,
				canScroll: false,
			};

			// Batch layout reads in one pass and reuse cached values during scroll-time paint.
			const measure = () => {
				const scrollY = window.scrollY || window.pageYOffset || document.documentElement.scrollTop || 0;
				const heroRect = hero ? hero.getBoundingClientRect() : null;
				const heroHeight = hero ? hero.offsetHeight : window.innerHeight;
				const viewportHeight = Math.max(1, viewport.offsetHeight);
				const paragraphHeight = Math.max(1, element.offsetHeight);
				const heroStart = heroRect ? heroRect.top + scrollY : scrollY;
				const heroTravel = Math.max(heroHeight - window.innerHeight, 1);
				const maxTranslate = Math.max(0, paragraphHeight - viewportHeight + (viewportHeight * 0.15));
				const fadeZone = Math.max(1, Math.min(120, viewportHeight * 0.25));
				const middleOffset = viewportHeight * 0.4;
				const scrollDenominator = Math.max(0.001, paragraphHeight - middleOffset);

				metrics.heroStart = heroStart;
				metrics.heroTravel = heroTravel;
				metrics.paragraphHeight = paragraphHeight;
				metrics.viewportHeight = viewportHeight;
				metrics.maxTranslate = maxTranslate;
				metrics.fadeZone = fadeZone;
				metrics.middleOffset = middleOffset;
				metrics.scrollDenominator = scrollDenominator;
				metrics.canScroll = maxTranslate > 0;

				for (let index = 0; index < chars.length; index += 1) {
					charPositions[index] = chars[index].offsetTop;
				}
			};

				return {
					element,
					chars,
					charPositions,
					metrics,
					measure,
				};
			};

		const splitTargets = Array.from(document.querySelectorAll('.cool-split'));
		const states = splitTargets.map(splitParagraph).filter(Boolean);
		if (states.length === 0) return;

			const stateByElement = new Map(states.map((state) => [state.element, state]));
			const activeStates = new Set();
			let frame = 0;
			let resizeFrame = 0;
			let initialMeasureFrame = 0;

		const getScrollProgress = (state) => {
			const scrollY = window.scrollY || window.pageYOffset || document.documentElement.scrollTop || 0;
			return clamp((scrollY - state.metrics.heroStart) / state.metrics.heroTravel, 0, 1);
		};

		const paintState = (state) => {
			const progress = getScrollProgress(state);
			const p = state.element;
			const viewport = p.parentElement; // .hero-side-viewport
			if (!(viewport instanceof HTMLElement)) return;
			const {
				paragraphHeight,
				maxTranslate,
				fadeZone,
				middleOffset,
				scrollDenominator,
				canScroll,
			} = state.metrics;

			// 1. Calculate scroll range
			// Text scrolls up just enough so the bottom line stays within the viewport.
			// The wave starts above the paragraph and sweeps to the bottom.
			const waveCharY = (progress * (paragraphHeight + fadeZone * 2)) - fadeZone;

			// 3. Apply scroll transform (delayed)
			// Don't start physically scrolling the block until the light-up wave reaches the target threshold
			const scrollProgress = clamp((waveCharY - middleOffset) / scrollDenominator, 0, 1);
			const translateY = canScroll ? scrollProgress * maxTranslate : 0;
			p.style.transform = `translate3d(0, ${-translateY}px, 0)`;

			// 4. Adjust dynamic CSS masks for soft fades
			// Top mask fades away as soon as you scroll, allowing the 'disappearing' fade effect.
			// Re-use physical scrollProgress so the top only masks exactly as text slides under it.
			const topOpacity = clamp(1 - (scrollProgress * 15), 0, 1);
			viewport.style.setProperty('--mask-top', topOpacity.toFixed(3));
			
			// Bottom mask only fades off if we actually overflowed, and only near the very bottom.
			if (canScroll) {
				// Base this mostly on overall progress so we can see the bottom text as it finishes
				const bottomOpacity = clamp((1 - progress) * 8, 0, 1);
				viewport.style.setProperty('--mask-bottom', bottomOpacity.toFixed(3));
			} else {
				viewport.style.setProperty('--mask-bottom', '1');
			}

			for (let index = 0; index < state.chars.length; index += 1) {
				const char = state.chars[index];
				const charY = state.charPositions[index] || 0;

				// Calculate distance of this character from the sweep wave.
				const distance = waveCharY - charY;

				// Normalize to roughly 0 (muted) or 1 (gold) based on distance
				const rawReveal = clamp((distance + fadeZone) / (fadeZone * 2), 0, 1);
				const easedReveal = rawReveal * rawReveal * (3 - 2 * rawReveal);
				char.style.setProperty('--reveal', easedReveal.toFixed(3));
			}
		};

		const update = () => {
			frame = 0;
			if (activeStates.size === 0) return;
			activeStates.forEach((state) => paintState(state));
		};

		const requestUpdate = () => {
			if (!frame) {
				frame = window.requestAnimationFrame(update);
			}
		};

		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					const state = stateByElement.get(entry.target);
					if (!state) return;

					if (entry.isIntersecting) {
						activeStates.add(state);
					} else {
						activeStates.delete(state);
					}
				});

				requestUpdate();
			},
			{
				rootMargin: '20% 0px 20% 0px',
				threshold: 0,
			},
		);

			states.forEach((state) => {
				observer.observe(state.element);
			});

			initialMeasureFrame = window.requestAnimationFrame(() => {
				initialMeasureFrame = 0;
				states.forEach((state) => state.measure());
				requestUpdate();
			});

			const refreshMeasurements = () => {
				if (resizeFrame) return;
				resizeFrame = window.requestAnimationFrame(() => {
					resizeFrame = 0;
					states.forEach((state) => state.measure());
					requestUpdate();
				});
			};
			const handleResize = () => {
				refreshMeasurements();
			};
			const handleLoad = () => {
				refreshMeasurements();
			};

			window.addEventListener('scroll', requestUpdate, { passive: true });
			window.addEventListener('resize', handleResize);
			window.addEventListener('orientationchange', handleResize);
			window.addEventListener('load', handleLoad, { once: true });

			if (document.fonts && document.fonts.ready && typeof document.fonts.ready.then === 'function') {
				document.fonts.ready
					.then(() => {
						handleLoad();
					})
					.catch(() => {});
			}

			window.__coolSplitCleanup = () => {
				observer.disconnect();
				window.removeEventListener('scroll', requestUpdate);
				window.removeEventListener('resize', handleResize);
				window.removeEventListener('orientationchange', handleResize);
				window.removeEventListener('load', handleLoad);
				if (frame) {
					window.cancelAnimationFrame(frame);
					frame = 0;
				}
				if (resizeFrame) {
					window.cancelAnimationFrame(resizeFrame);
					resizeFrame = 0;
				}
				if (initialMeasureFrame) {
					window.cancelAnimationFrame(initialMeasureFrame);
					initialMeasureFrame = 0;
				}
				states.forEach((state) => {
					const originalText = state.element.dataset.splitOriginalText;
					if (typeof originalText === 'string') {
						state.element.textContent = originalText;
					}
					state.element.style.transform = '';
					delete state.element.dataset.splitDone;
					const viewport = state.element.parentElement;
					if (viewport instanceof HTMLElement) {
						viewport.style.removeProperty('--mask-top');
						viewport.style.removeProperty('--mask-bottom');
					}
				});
				activeStates.clear();
			};
		}

		function cleanupCoolSplit() {
			if (window.__coolSplitCleanup) {
				window.__coolSplitCleanup();
				window.__coolSplitCleanup = null;
			}
		}

		function cleanupHeroNoButton() {
			if (window.__heroNoButtonCleanup) {
				window.__heroNoButtonCleanup();
				window.__heroNoButtonCleanup = null;
		}
	}

	function initHeroNoButton() {
		cleanupHeroNoButton();

		if (!window.matchMedia('(pointer: fine)').matches) return;

		const button = document.querySelector('.hero-secondary-btn');
		if (!button || button.offsetParent === null) return;

		const viewportPadding = 24;
		const collisionSelector = 'p, h1, h2, h3, h4, h5, h6, span, button, a.btn';
		const idleReturnDelay = 5000;

			const isVisible = (element) => {
				if (!(element instanceof HTMLElement)) return false;
				if (element === button || element.contains(button) || button.contains(element)) return false;

				const style = window.getComputedStyle(element);
				if (style.display === 'none' || style.visibility === 'hidden' || parseFloat(style.opacity) === 0) {
					return false;
				}
				return true;
			};

			const getCollisionRects = () => {
				const rects = [];
				const candidates = Array.from(document.querySelectorAll(collisionSelector));
				for (let index = 0; index < candidates.length; index += 1) {
					const candidate = candidates[index];
					if (!isVisible(candidate)) continue;
					const rect = candidate.getBoundingClientRect();
					if (rect.width <= 0 || rect.height <= 0) continue;
					rects.push(rect);
				}
				return rects;
			};

		const overlaps = (a, b) =>
			a.left < b.right && a.right > b.left && a.top < b.bottom && a.bottom > b.top;

			const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
			let resetFrame = 0;
			let moveFrame = 0;
			let returnTimer = 0;
			let returnTransitionHandler = null;
			let originRect = null;

		const clearReturnTimer = () => {
			if (returnTimer) {
				window.clearTimeout(returnTimer);
				returnTimer = 0;
			}
		};

		const clearReturnTransition = () => {
			if (returnTransitionHandler) {
				button.removeEventListener('transitionend', returnTransitionHandler);
				returnTransitionHandler = null;
			}
		};

		const resetButtonPosition = () => {
			clearReturnTimer();
			clearReturnTransition();

			if (resetFrame) {
				window.cancelAnimationFrame(resetFrame);
			}

			resetFrame = window.requestAnimationFrame(() => {
				resetFrame = 0;
				button.classList.remove('is-returning');
				button.classList.remove('is-floating');
				delete button.dataset.escapeFixed;
				originRect = null;
				button.style.position = '';
				button.style.left = '';
				button.style.top = '';
				button.style.width = '';
				button.style.height = '';
				button.style.zIndex = '';
			});
		};

		const lockButtonToViewport = () => {
			if (button.dataset.escapeFixed === 'true') {
				return button.getBoundingClientRect();
			}

			const rect = button.getBoundingClientRect();
			originRect = rect;
			button.classList.remove('is-returning');
			button.classList.add('is-floating');
			button.style.position = 'fixed';
			button.style.left = `${rect.left}px`;
			button.style.top = `${rect.top}px`;
				button.style.width = `${Math.ceil(rect.width)}px`;
				button.style.height = `${Math.ceil(rect.height)}px`;
				button.style.zIndex = '90';
				button.dataset.escapeFixed = 'true';
				return rect;
			};

		const scheduleReturnToOrigin = () => {
			clearReturnTimer();

			returnTimer = window.setTimeout(() => {
				if (button.dataset.escapeFixed !== 'true' || !originRect) return;

				clearReturnTransition();
				returnTransitionHandler = (event) => {
					if (event.propertyName !== 'left') return;
					clearReturnTransition();
					resetButtonPosition();
				};

				button.addEventListener('transitionend', returnTransitionHandler);
				button.classList.add('is-returning');
				button.style.left = `${originRect.left}px`;
				button.style.top = `${originRect.top}px`;
			}, idleReturnDelay);
		};

			const getSafeRect = (originRect, collisionRects) => {
				const buttonRect = originRect || button.getBoundingClientRect();
				const buttonWidth = buttonRect.width;
				const buttonHeight = buttonRect.height;
			const maxLeft = Math.max(viewportPadding, window.innerWidth - buttonWidth - viewportPadding);
			const maxTop = Math.max(viewportPadding, window.innerHeight - buttonHeight - viewportPadding);
			const minTravel = Math.min(120, Math.max(56, Math.min(window.innerWidth, window.innerHeight) * 0.07));
			const localRangeX = Math.min(190, Math.max(96, window.innerWidth * 0.16));
			const localRangeY = Math.min(140, Math.max(72, window.innerHeight * 0.14));

			let nextRect = null;
			let hasCollision = true;
			let attempts = 0;

			while (hasCollision && attempts < 240) {
				const spread =
					attempts < 120 ? 1 : attempts < 190 ? 1.65 : 2.3;
				const deltaX = (Math.random() * 2 - 1) * localRangeX * spread;
				const deltaY = (Math.random() * 2 - 1) * localRangeY * spread;
				const travel = Math.hypot(deltaX, deltaY);

				if (travel < minTravel) {
					attempts += 1;
					continue;
				}

				const left = clamp(buttonRect.left + deltaX, viewportPadding, maxLeft);
				const top = clamp(buttonRect.top + deltaY, viewportPadding, maxTop);

				nextRect = {
					left,
					top,
					right: left + buttonWidth,
					bottom: top + buttonHeight,
				};

					hasCollision = collisionRects.some((collisionRect) => overlaps(nextRect, collisionRect));

					attempts += 1;
				}

			return hasCollision ? null : nextRect;
		};

			const moveButton = () => {
				if (!window.matchMedia('(pointer: fine)').matches) return;

				const originRect = lockButtonToViewport();
				if (moveFrame) {
					window.cancelAnimationFrame(moveFrame);
				}

				moveFrame = window.requestAnimationFrame(() => {
					moveFrame = 0;
					if (button.dataset.escapeFixed !== 'true') return;
					const collisionRects = getCollisionRects();
					const safeRect = getSafeRect(originRect, collisionRects);
					if (!safeRect) return;
					button.classList.remove('is-returning');
					button.style.left = `${safeRect.left}px`;
					button.style.top = `${safeRect.top}px`;
					scheduleReturnToOrigin();
				});
			};

		const handleViewportChange = () => {
			if (button.dataset.escapeFixed === 'true') {
				resetButtonPosition();
			}
		};

		button.addEventListener('mouseenter', moveButton);
		button.addEventListener('mouseleave', scheduleReturnToOrigin);
		window.addEventListener('scroll', handleViewportChange, { passive: true });
		window.addEventListener('resize', handleViewportChange);
		window.addEventListener('orientationchange', handleViewportChange);
		window.addEventListener('hashchange', handleViewportChange);

			window.__heroNoButtonCleanup = () => {
				if (resetFrame) {
					window.cancelAnimationFrame(resetFrame);
					resetFrame = 0;
				}
				if (moveFrame) {
					window.cancelAnimationFrame(moveFrame);
					moveFrame = 0;
				}
				button.removeEventListener('mouseenter', moveButton);
				button.removeEventListener('mouseleave', scheduleReturnToOrigin);
			window.removeEventListener('scroll', handleViewportChange);
			window.removeEventListener('resize', handleViewportChange);
			window.removeEventListener('orientationchange', handleViewportChange);
			window.removeEventListener('hashchange', handleViewportChange);
			resetButtonPosition();
		};
	}

	const initHeroSection = () => {
		initCoolSplit();
		initHeroNoButton();
	};

	let scheduledHeroInitId = 0;

	const clearScheduledHeroInit = () => {
		if (!scheduledHeroInitId) return;
		if ('cancelIdleCallback' in window) {
			window.cancelIdleCallback(scheduledHeroInitId);
		} else {
			window.clearTimeout(scheduledHeroInitId);
		}
		scheduledHeroInitId = 0;
	};

	const runHeroInit = () => {
		scheduledHeroInitId = 0;
		initHeroSection();
	};

	const scheduleHeroInit = () => {
		if (scheduledHeroInitId) return;
		if ('requestIdleCallback' in window) {
			scheduledHeroInitId = window.requestIdleCallback(runHeroInit, { timeout: 1200 });
			return;
		}
		scheduledHeroInitId = window.setTimeout(runHeroInit, 180);
	};

		scheduleHeroInit();
		document.addEventListener('astro:page-load', scheduleHeroInit);
		document.addEventListener('astro:before-swap', () => {
			clearScheduledHeroInit();
			cleanupCoolSplit();
			cleanupHeroNoButton();
		});
	</script>
