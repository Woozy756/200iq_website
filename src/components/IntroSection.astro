---
import HeroFluidBackgroundIsland from '/src/islands/HeroFluidBackgroundIsland.jsx';
import { normalizeLang, useTranslations } from '../i18n/utils';

interface Props {
	lang: string;
}

const lang = normalizeLang(Astro.props.lang);
const t = useTranslations(lang);
---

<section class="hero section">
	<div class="hero-stage">
		<HeroFluidBackgroundIsland client:visible />

		<div class="container hero-content">
			<div class="hero-grid">
				<div class="hero-main">
					<p class="hero-kicker">{t('intro.kicker')}</p>
					<h1 class="hero-title">
						{t('intro.titleStart')} <span class="accent">{t('intro.titleHighlight')}</span><br />{t(
							'intro.titleEnd',
						)}
					</h1>
					<div class="hero-actions">
						<a href="#process" class="btn btn-primary">{t('navigation.cta')}</a>
						<a href="#tech" class="btn btn-dark">{t('navigation.links.tech')}</a>
					</div>
				</div>
				<div class="hero-side">
					<p class="hero-lead cool-split">{t('intro.lead')}</p>
				</div>
			</div>
		</div>
	</div>
</section>

<script is:inline>
	const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

	const splitParagraph = (element) => {
		const text = element.textContent || '';
		element.setAttribute('aria-label', text);
		element.textContent = '';

		const fragment = document.createDocumentFragment();
		const chars = [];

		Array.from(text).forEach((character) => {
			if (character === ' ') {
				fragment.appendChild(document.createTextNode(' '));
				return;
			}

			const span = document.createElement('span');
			span.className = 'char';
			span.textContent = character;
			span.style.setProperty('--reveal', '0');
			span.setAttribute('aria-hidden', 'true');
			fragment.appendChild(span);
			chars.push(span);
		});

		element.appendChild(fragment);
		return {
			element,
			chars,
		};
	};

	const splitTargets = Array.from(document.querySelectorAll('.cool-split'));
	const states = splitTargets.map(splitParagraph);
	let frame = 0;

	const getScrollProgress = (state) => {
		const hero = state.element.closest('.hero');
		if (!hero) return 0;

		const stage = state.element.closest('.hero-stage');
		const stagePosition = stage ? window.getComputedStyle(stage).position : '';

		// Desktop uses sticky stage + long hero travel.
		if (stagePosition === 'sticky') {
			const heroRect = hero.getBoundingClientRect();
			const heroTravel = Math.max(hero.offsetHeight - window.innerHeight, 1);
			return clamp(-heroRect.top / heroTravel, 0, 1);
		}

		// Mobile/tablet fallback tracks the paragraph through the viewport.
		const paragraphRect = state.element.getBoundingClientRect();
		const start = window.innerHeight * 0.9;
		const end = window.innerHeight * 0.2;
		return clamp((start - paragraphRect.top) / Math.max(start - end, 1), 0, 1);
	};

	const paintState = (state) => {
		const progress = getScrollProgress(state);
		const totalChars = Math.max(state.chars.length, 1);
		const fadeWindow = 0.2;
		const maxStart = Math.max(1 - fadeWindow, 0);
		const lastIndex = Math.max(totalChars - 1, 1);

		state.chars.forEach((char, index) => {
			const charStart = (index / lastIndex) * maxStart;
			const charEnd = charStart + fadeWindow;
			const rawReveal = clamp((progress - charStart) / Math.max(charEnd - charStart, 0.0001), 0, 1);
			const easedReveal = rawReveal * rawReveal * (3 - 2 * rawReveal);
			char.style.setProperty('--reveal', easedReveal.toFixed(3));
		});
	};

	const update = () => {
		frame = 0;
		states.forEach((state) => paintState(state));
	};

	const requestUpdate = () => {
		if (!frame) {
			frame = window.requestAnimationFrame(update);
		}
	};

	states.forEach((state) => paintState(state));
	requestUpdate();

	window.addEventListener('scroll', requestUpdate, { passive: true });
	window.addEventListener('resize', requestUpdate);
	window.addEventListener('orientationchange', requestUpdate);
</script>
