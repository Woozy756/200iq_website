---
import { getImage } from 'astro:assets';
import brandLogo from '../assets/200iq_logo.png';
import FooterSection from './FooterSection.astro';
import ContactForm from './ContactForm.jsx';
import NavMenu from './NavMenu.astro';
import Layout from '../layouts/Layout.astro';
import { localeEndonyms } from '../i18n/ui';
import { getDictionary, getLocalizedPath, normalizeLang, useTranslations } from '../i18n/utils';

interface Props {
	lang: string;
}

const lang = normalizeLang(Astro.props.lang);
const t = useTranslations(lang);
const dictionary = getDictionary(lang);
const [navLogoSm, navLogoMd, navLogoLg] = await Promise.all([
	getImage({ src: brandLogo, width: 160, format: 'png' }),
	getImage({ src: brandLogo, width: 260, format: 'png' }),
	getImage({ src: brandLogo, width: 420, format: 'png' }),
]);
const navLogoSrcSet = `${navLogoSm.src} 160w, ${navLogoMd.src} 260w, ${navLogoLg.src} 420w`;
const navLogoSizes = '(max-width: 720px) 124px, 208px';

const navLinks = [
	{ label: t('navigation.links.process'), href: getLocalizedPath(lang), targetId: 'process' },
	{ label: t('navigation.links.tech'), href: getLocalizedPath(lang), targetId: 'services' },
	{ label: t('navigation.links.network'), href: getLocalizedPath(lang), targetId: 'network' },
];

const localeLinks = [
	{ code: 'lv', label: localeEndonyms.lv, flagCode: 'lv', href: getLocalizedPath('lv', '/contact') },
	{ code: 'en', label: localeEndonyms.en, flagCode: 'gb', href: getLocalizedPath('en', '/contact') },
	{ code: 'ru', label: localeEndonyms.ru, flagCode: 'ru', href: getLocalizedPath('ru', '/contact') },
	{ code: 'et', label: localeEndonyms.et, flagCode: 'ee', href: getLocalizedPath('et', '/contact') },
];
---

<Layout
	lang={lang}
	title={dictionary.metadata.contactTitle}
	description={dictionary.metadata.contactDescription}
>
	<NavMenu
		brand={t('navigation.brand')}
		links={navLinks}
		localeLinks={localeLinks}
		currentLocale={lang}
		logoSrc={navLogoMd.src}
		logoSrcSet={navLogoSrcSet}
		logoSizes={navLogoSizes}
		logoWidth={260}
		logoHeight={77}
		ctaLabel={t('navigation.cta')}
		openMenuLabel={t('navigation.openMenu')}
		closeMenuLabel={t('navigation.closeMenu')}
		languageLabel={t('navigation.languageLabel')}
	/>

	<main class="contact-main">
		<section class="hero section contact-hero">
			<div class="container hero-content">
				<div class="hero-grid contact-grid">
					<div class="hero-main">
						<p class="eyebrow">{t('contact.eyebrow')}</p>
						<h1 class="hero-title">
							{t('contact.titleStart')} <span class="accent">{t('contact.titleHighlight')}</span>
						</h1>
						<p class="hero-lead mt-6">
							{t('contact.lead')}
						</p>
					</div>
					<div class="contact-form-wrapper panel">
						<ContactForm client:visible t={dictionary.contact.form} />
					</div>
				</div>
			</div>
		</section>
	</main>

	<FooterSection lang={lang} />
</Layout>

<style>
	.contact-main {
		padding-top: 0;
		background: #000;
	}

	.contact-hero {
		min-height: 100vh;
		display: flex;
		align-items: center;
		position: relative;
		background: #000;
	}

	.contact-hero::before {
		content: none;
	}

	.contact-grid {
		grid-template-columns: 1fr 1.15fr;
		gap: clamp(2rem, 5vw, 4rem);
		align-items: center;
	}

	@media (max-width: 900px) {
		.contact-grid {
			grid-template-columns: 1fr;
			gap: 3.5rem;
		}

		.contact-form-wrapper {
			padding-inline: 0;
			width: 100%;
			margin-top: 0;
		}
	}

	.mt-6 {
		margin-top: 1.5rem;
	}

	.contact-form-wrapper {
		padding: clamp(1.5rem, 4vw, 3rem);
		margin-top: clamp(3rem, 7vh, 4.5rem);
		z-index: 2;
	}
</style>
